{
  "openapi": "3.0.0",
  "info": {
    "title": "Book Library API",
    "description": "CRUD API for managing Books and Authors - CSE-341 Project 2",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://cse-341-project2-ea66.onrender.com",
      "description": "Production (Render)"
    }
  ],
  "paths": {
    "/api/books": {
      "get": {
        "summary": "Get all books",
        "responses": {
          "200": {
            "description": "Array of books"
          }
        }
      },
      "post": {
        "summary": "Create a new book",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["title", "author"],
                "properties": {
                  "title": { "type": "string" },
                  "author": { "type": "string" },
                  "isbn": { "type": "string" },
                  "genre": {
                    "type": "string",
                    "enum": ["Fiction", "Non-Fiction", "Sci-Fi", "Fantasy", "Mystery", "Biography", "Other"]
                  },
                  "publicationYear": { "type": "integer", "minimum": 1000 },
                  "pageCount": { "type": "integer", "minimum": 1 },
                  "description": { "type": "string", "maxLength": 1000 },
                  "coverImageUrl": { "type": "string" },
                  "rating": { "type": "number", "minimum": 0, "maximum": 5 },
                  "isRead": { "type": "boolean" },
                  "userNotes": { "type": "string" }
                }
              },
              "example": {
                "title": "Atomic Habits",
                "author": "James Clear",
                "isbn": "9780735211292",
                "genre": "Other",
                "publicationYear": 2018,
                "pageCount": 320,
                "description": "A guide on how small habits can lead to big improvements in life.",
                "coverImageUrl": "https://images-na.ssl-images-amazon.com/images/I/91bYsX41DVL.jpg",
                "rating": 5,
                "isRead": true,
                "userNotes": "Helped me build better daily routines."
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Book created" },
          "400": { "description": "Validation error" }
        }
      }
    },
    "/api/books/{id}": {
      "get": {
        "summary": "Get book by ID",
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Book object" },
          "404": { "description": "Not found" }
        }
      },
      "put": {
        "summary": "Update book",
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "type": "object" }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated book" },
          "400": { "description": "Validation error" },
          "404": { "description": "Not found" }
        }
      },
      "delete": {
        "summary": "Delete book",
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Deleted successfully" },
          "404": { "description": "Not found" }
        }
      }
    },
    "/api/authors": {
      "get": {
        "summary": "Get all authors",
        "responses": {
          "200": { "description": "Array of authors" }
        }
      },
      "post": {
        "summary": "Create a new author",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": { "type": "string" },
                  "bio": { "type": "string", "maxLength": 1000 },
                  "nationality": { "type": "string" },
                  "birthYear": { "type": "integer", "minimum": 1500 },
                  "website": { "type": "string" },
                  "photoUrl": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Author created" },
          "400": { "description": "Validation error" }
        }
      }
    },
    "/api/authors/{id}": {
      "get": {
        "summary": "Get author by ID",
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Author object" },
          "404": { "description": "Not found" }
        }
      },
      "put": {
        "summary": "Update author",
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "type": "object" }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated author" },
          "400": { "description": "Validation error" },
          "404": { "description": "Not found" }
        }
      },
      "delete": {
        "summary": "Delete author",
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Deleted successfully" },
          "404": { "description": "Not found" }
        }
      }
    }
  }
}